{
  "name": "fontgenerator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:e2e": "VITE_E2E_HOOKS=true npm run build",
    "ci": "npm run build && npm test && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "lint": "eslint .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@types/pngjs": "^6.0.5",
    "ai": "^6.0.217",
    "buffer": "^6.0.3",
    "jszip": "^3.10.1",
    "opentype.js": "^2.0.0",
    "pngjs": "^7.0.0",
    "potrace-wasm": "^1.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svg-path-parser": "^1.1.0",
    "wawoff2": "^2.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^28.1.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
