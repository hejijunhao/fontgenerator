# OpenRouter API key for hosted agent mode.
# In local dev, Vite's /api/agent proxy injects this automatically when set.
# On Vercel, set OPENROUTER_API_KEY in project environment variables.
OPENROUTER_API_KEY=sk-or-v1-...

# Canonical site URL for sitemap, canonical links, and Open Graph (production deploy).
# VITE_SITE_URL=https://glyphmill.vercel.app